deactivate() {
    unalias spine1
    unalias spine2
    unalias leaf1
    unalias leaf2
    unalias leaf3
}

alias spine1="sshpass -p root ssh -A -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null root@clab-lab-spine1"
alias spine2="sshpass -p root ssh -A -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null root@clab-lab-spine2"
alias leaf1="sshpass -p root ssh -A -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null root@clab-lab-leaf1"
alias leaf2="sshpass -p root ssh -A -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null root@clab-lab-leaf2"
alias leaf3="sshpass -p root ssh -A -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null root@clab-lab-leaf3"
